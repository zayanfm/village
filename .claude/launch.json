{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Expo Dev Server",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["start"],
      "port": 8081
    },
    {
      "name": "Expo (Android)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "android"],
      "port": 8081
