// User Service — identity, RBAC, persona profiles, and the worker<->youth
// relationship mapping. ACID/relational => PostgreSQL.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---- identity (auth) ----
model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String   @map("password_hash")
  status       String   @default("active")
  createdAt    DateTime @default(now()) @map("created_at")

  roles         UserRole[]
  youthProfile  YouthProfile?
  workerProfile WorkerProfile?
  youthCases    CaseAssignment[] @relation("YouthCases")
  workerCases   CaseAssignment[] @relation("WorkerCases")

  @@map("users")
}

// ---- RBAC core ----
model Role {
  id          Int              @id // 1='youth', 2='worker', 3='worker_admin'
  name        String           @unique
  users       UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id    Int              @id @default(autoincrement())
  key   String           @unique // e.g. 'journal:write', 'calendar:manage'
  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId Int @map("role_id")
  permId Int @map("perm_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permId], references: [id], onDelete: Cascade)

  @@id([roleId, permId])
  @@map("role_permissions")
}

model UserRole {
  userId String @map("user_id") @db.Uuid
  roleId Int    @map("role_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

// ---- persona profiles (sparse 1:1) ----
model YouthProfile {
  userId           String    @id @map("user_id") @db.Uuid
  displayName      String?   @map("display_name")
  membershipStatus String?   @map("membership_status") // 'Active Member'
  joinedAt         DateTime? @map("joined_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("youth_profiles")
}

model WorkerProfile {
  userId   String  @id @map("user_id") @db.Uuid
  fullName String? @map("full_name")
  orgUnit  String? @map("org_unit")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("worker_profiles")
}

// ---- the worker<->youth case mapping ----
model CaseAssignment {
  caseId     String   @id @map("case_id") // e.g. 'H-008'
  youthId    String   @map("youth_id") @db.Uuid
  workerId   String   @map("worker_id") @db.Uuid
  status     String   @default("open")
  assignedAt DateTime @default(now()) @map("assigned_at")

  youth  User @relation("YouthCases", fields: [youthId], references: [id])
  worker User @relation("WorkerCases", fields: [workerId], references: [id])

  @@unique([youthId, workerId])
  @@map("case_assignments")
}
