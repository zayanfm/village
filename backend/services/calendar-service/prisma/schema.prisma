// Calendar Service — WORKER-ONLY scheduling. Relational/ACID => PostgreSQL.
//
// NOTE: the no-double-booking guard is a Postgres GiST exclusion constraint that
// Prisma's schema language can't express. Add it via a migration SQL step:
//
//   ALTER TABLE events ADD CONSTRAINT events_no_overlap
//     EXCLUDE USING gist (worker_id WITH =, tstzrange(starts_at, ends_at) WITH &&);
//
// (requires: CREATE EXTENSION IF NOT EXISTS btree_gist;)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Availability {
  id       String @id @default(uuid()) @db.Uuid
  workerId String @map("worker_id") @db.Uuid
  weekday  Int // 0..6 (Sun..Sat)
  startMin Int    @map("start_min") // minutes from midnight
  endMin   Int    @map("end_min")

  @@index([workerId])
  @@map("availability")
}

model Event {
  id       String   @id @default(uuid()) @db.Uuid
  workerId String   @map("worker_id") @db.Uuid
  caseId   String?  @map("case_id") // optional link to a case (e.g. 'H-008')
  title    String
  startsAt DateTime @map("starts_at")
  endsAt   DateTime @map("ends_at")
  rrule    String? // iCal RRULE for recurrence

  reminders Reminder[]

  @@index([workerId, startsAt])
  @@map("events")
}

model Reminder {
  id       String   @id @default(uuid()) @db.Uuid
  eventId  String   @map("event_id") @db.Uuid
  remindAt DateTime @map("remind_at")
  channel  String   @default("push")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([remindAt])
  @@map("reminders")
}
