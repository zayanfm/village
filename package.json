{
  "name": "unigarden",
  "version": "1.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "dev:ai": "npm run dev --prefix backend/services/ai-service",
    "dev:backend": "concurrently --kill-others-on-fail --prefix-colors \"bgBlue,bgGreen,bgYellow,bgMagenta,bgCyan,bgRed\" --names \"USER,HOUSE,JOURNAL,ENGAGE,CAL,AI\" \"npm run dev --prefix backend/services/user-service\" \"npm run dev --prefix backend/services/house-service\" \"npm run dev --prefix backend/services/journaling-service\" \"npm run dev --prefix backend/services/engagement-service\" \"npm run dev --prefix backend/services/calendar-service\" \"npm run dev --prefix backend/services/ai-service\"",
    "dev:youth": "powershell -ExecutionPolicy Bypass -File scripts/dev-youth.ps1",
    "dev": "powershell -ExecutionPolicy Bypass -File scripts/dev-all.ps1"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-navigation/bottom-tabs": "^6.5.20",
    "@react-navigation/native": "^6.1.17",
    "@react-navigation/native-stack": "^6.9.26",
    "@react-three/fiber": "^9.6.1",
    "expo": "^54.0.35",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.13",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.23",
    "expo-gl": "~16.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "firebase": "^12.15.0",
    "jszip": "^3.10.1",
    "moti": "^0.30.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-worklets": "0.5.1",
    "three": "^0.169.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "babel-preset-expo": "~54.0.10",
    "concurrently": "^10.0.3",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "private": true
}
